# ─────────────────────────────────────────────────────────────────────────────
# PANACEA — Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to git
# ─────────────────────────────────────────────────────────────────────────────


# ── OpenAI ────────────────────────────────────────────────────────────────────
# Your OpenAI API key (get it from https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Which GPT model to use for specialist agents
# Options: gpt-4o | gpt-4o-mini (cheaper) | gpt-4-turbo
OPENAI_MODEL=gpt-4o


# ── MongoDB ───────────────────────────────────────────────────────────────────
# Option A: Local MongoDB (if running MongoDB on your machine)
MONGODB_URI=mongodb://localhost:27017

# Option B: MongoDB Atlas (cloud) — uncomment and replace with your cluster URL
# MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/

# Name of the MongoDB database
MONGODB_DB_NAME=panacea


# ── Voice Settings ────────────────────────────────────────────────────────────
# Whisper model size (runs locally, no API cost)
# Smaller = faster but less accurate | Larger = slower but more accurate
# Options: tiny | base | small | medium | large-v3
# Recommended for dev: base | Recommended for production: small or medium
WHISPER_MODEL=base

# Whisper device — use "cpu" if no GPU, "cuda" if you have NVIDIA GPU
WHISPER_DEVICE=cpu

# Text-to-speech speaking rate (words per minute)
# Default 150 is natural pace. Lower = slower, higher = faster
TTS_RATE=150

# TTS voice gender preference (depends on your OS voices)
# Options: male | female
TTS_VOICE=female


# ── Backend API ───────────────────────────────────────────────────────────────
BACKEND_HOST=localhost
BACKEND_PORT=8000


# ── App Settings ──────────────────────────────────────────────────────────────
# How many conversation turns a specialist does before giving summary
# More turns = more thorough interview, fewer = faster
MAX_SPECIALIST_TURNS=5

# Log level
# Options: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
