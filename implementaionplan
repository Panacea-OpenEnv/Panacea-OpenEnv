2c. CREATE src/inference/inference_server.py
Thin HTTP client that calls the remote Colab/HuggingFace endpoint. No local GPU needed.

OVERSIGHT_ENDPOINT = os.getenv("OVERSIGHT_ENDPOINT")  # e.g. https://abc.ngrok.io/generate
OVERSIGHT_API_KEY  = os.getenv("OVERSIGHT_API_KEY", "")

async def query_oversight_model(prompt: str) -> dict:
    """POST prompt to remote endpoint; return parsed {decision, fraud_flags, reasoning}."""
    resp = await httpx.AsyncClient().post(
        OVERSIGHT_ENDPOINT,
        json={"prompt": prompt},
        headers={"Authorization": f"Bearer {OVERSIGHT_API_KEY}"},
        timeout=30.0,
    )
    return _parse_response(resp.json()["text"])

def _parse_response(text: str) -> dict:
    """Extract JSON from model output; fall back to deterministic rules on parse failure."""
The fallback to deterministic rules on parse failure means production never breaks if the model is unreachable.

