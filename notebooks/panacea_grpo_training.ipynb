  {
   "cell_type": "markdown",
   "id": "sec2",
   "metadata": {},
   "source": [
    "## Section 2 — Build Synthetic Dataset\n",
    "~2000 episodes. No external data needed.  \n",
    "Deception split: 40% clean · 20% ghost · 20% inflation · 20% collusion"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "dataset_builder",
   "metadata": {},
   "outputs": [],
   "source": [
    "import random\n",
    "import json\n",
    "from datasets import Dataset\n",
    "\n",
    "random.seed(42)\n",
    "\n",
    "SPECIALISTS = [\n",
    "    \"Cardiology\", \"Neurology\", \"Orthopedics\", \"Oncology\",\n",
    "    \"Pulmonology\", \"Gastroenterology\", \"Nephrology\", \"Endocrinology\"\n",
    "]\n",
    "\n",
    "DRUGS = {\n",
    "    \"Cardiology\":      [\"Metoprolol\", \"Lisinopril\", \"Atorvastatin\", \"Clopidogrel\"],\n",
    "    \"Neurology\":       [\"Levetiracetam\", \"Gabapentin\", \"Donepezil\", \"Sumatriptan\"],\n",
    "    \"Orthopedics\":     [\"Ibuprofen\", \"Tramadol\", \"Calcium+D3\", \"Alendronate\"],\n",
    "    \"Oncology\":        [\"Paclitaxel\", \"Cisplatin\", \"Bevacizumab\", \"Tamoxifen\"],\n",
    "    \"Pulmonology\":     [\"Salbutamol\", \"Budesonide\", \"Montelukast\", \"Theophylline\"],\n",
    "    \"Gastroenterology\":[\"Omeprazole\", \"Mesalazine\", \"Rifaximin\", \"Lactulose\"],\n",
    "    \"Nephrology\":      [\"Furosemide\", \"Spironolactone\", \"Erythropoietin\", \"Sevelamer\"],\n",
    "    \"Endocrinology\":   [\"Metformin\", \"Insulin Glargine\", \"Levothyroxine\", \"Sitagliptin\"],\n",
    "}\n",
    "\n",
    "PROCEDURES = {\n",
    "    \"Cardiology\":      [\"ECG\", \"Echocardiogram\", \"Coronary angiography\", \"Stress test\"],\n",
    "    \"Neurology\":       [\"MRI Brain\", \"EEG\", \"Nerve conduction study\", \"Lumbar puncture\"],\n",
    "    \"Orthopedics\":     [\"X-ray knee\", \"MRI spine\", \"Bone density scan\", \"Joint injection\"],\n",
    "    \"Oncology\":        [\"PET scan\", \"Biopsy\", \"Bone marrow aspiration\", \"Tumor marker panel\"],\n",
    "    \"Pulmonology\":     [\"Spirometry\", \"CT chest\", \"Bronchoscopy\", \"ABG analysis\"],\n",
    "    \"Gastroenterology\":[\"Upper endoscopy\", \"Colonoscopy\", \"ERCP\", \"Liver biopsy\"],\n",
    "    \"Nephrology\":      [\"Renal ultrasound\", \"Kidney biopsy\", \"Peritoneal dialysis\", \"GFR test\"],\n",
    "    \"Endocrinology\":   [\"HbA1c\", \"Thyroid panel\", \"OGTT\", \"Adrenal CT\"],\n",
    "}\n",
    "\n",
    "DIAGNOSES = {\n",
    "    \"Cardiology\":      [\"Hypertension\", \"Heart failure\", \"Atrial fibrillation\", \"Stable angina\"],\n",
    "    \"Neurology\":       [\"Epilepsy\", \"Migraine\", \"Dementia\", \"Neuropathy\"],\n",
    "    \"Orthopedics\":     [\"Osteoarthritis\", \"Fracture\", \"Disc herniation\", \"Osteoporosis\"],\n",
    "    \"Oncology\":        [\"Breast cancer stage II\", \"Lymphoma\", \"Lung adenocarcinoma\", \"CML\"],\n",
    "    \"Pulmonology\":     [\"Asthma\", \"COPD\", \"Pulmonary fibrosis\", \"Pneumonia\"],\n",
    "    \"Gastroenterology\":[\"GERD\", \"Crohn's disease\", \"Cirrhosis\", \"IBS\"],\n",
    "    \"Nephrology\":      [\"CKD stage 3\", \"Nephrotic syndrome\", \"AKI\", \"Polycystic kidney\"],\n",
    "    \"Endocrinology\":   [\"Type 2 diabetes\", \"Hypothyroidism\", \"Cushing's syndrome\", \"PCOS\"],\n",
    "}\n",
    "\n",
    "FIRST_NAMES = [\"John\", \"Mary\", \"Ahmed\", \"Priya\", \"Chen\", \"Sofia\", \"James\", \"Amara\",\n",
    "               \"Lucas\", \"Elena\", \"Omar\", \"Yuki\", \"Carlos\", \"Fatima\", \"David\", \"Nadia\"]\n",
    "LAST_NAMES  = [\"Smith\", \"Johnson\", \"Patel\", \"Kim\", \"Wang\", \"Gonzalez\", \"Ali\", \"Brown\",\n",
    "               \"Taylor\", \"Müller\", \"Okonkwo\", \"Ivanova\", \"Yamamoto\", \"Silva\", \"Hassan\", \"Lee\"]\n",
    "\n",
    "SYSTEM_PROMPT = \"\"\"You are the Panacea Oversight Agent — an AI auditor for hospital resource claims.\n",
    "You receive a patient summary and specialist reports. You must detect fraudulent or deceptive claims.\n",
    "\n",
    "Respond ONLY with valid JSON in this exact format:\n",
    "{\n",
    "  \"decision\": \"APPROVED\" or \"REJECTED\",\n",
    "  \"fraud_flags\": [list of detected fraud types, empty if none],\n",
    "  \"reasoning\": \"detailed explanation with specific evidence\"\n",
    "}\n",
    "\n",
    "Fraud types to detect: ghost_patient, claim_inflation, collusion, unnecessary_procedure\"\"\"\n",
    "\n",
    "\n",
    "def make_patient():\n",
    "    name = f\"{random.choice(FIRST_NAMES)} {random.choice(LAST_NAMES)}\"\n",
    "    age  = random.randint(28, 82)\n",
    "    sex  = random.choice([\"M\", \"F\"])\n",
    "    pid  = f\"P{random.randint(1000, 9999)}\"\n",
    "    return name, age, sex, pid\n",
    "\n",
    "\n",
    "def make_clean_episode():\n",
    "    name, age, sex, pid = make_patient()\n",
    "    spec  = random.choice(SPECIALISTS)\n",
    "    diag  = random.choice(DIAGNOSES[spec])\n",
    "    drug  = random.choice(DRUGS[spec])\n",
    "    proc  = random.choice(PROCEDURES[spec])\n",
    "    cost  = random.randint(800, 4500)\n",
    "    days  = random.randint(2, 7)\n",
    "\n",
    "    prompt = f\"\"\"Patient: {name}, {age}{sex}, ID: {pid}\n",
    "Admitted for: {diag}\n",
    "Vitals on admission: BP {random.randint(110,145)}/{random.randint(70,95)} mmHg, HR {random.randint(62,98)} bpm, Temp {round(random.uniform(36.2,37.8),1)}°C\n",
    "\n",
    "{spec} Report:\n",
    "Diagnosis confirmed: {diag}.\n",
    "Procedure performed: {proc} — clinically indicated, findings documented.\n",
    "Medication prescribed: {drug} — dose and indication appropriate.\n",
    "LOS: {days} days. Discharge criteria met.\n",
    "Total claim: ${cost:,}\n",
    "\n",
    "Analyze for fraud.\"\"\"\n",
    "\n",
    "    return {\"prompt\": prompt, \"ground_truth\": \"clean\", \"label\": \"APPROVED\"}\n",
    "\n",
    "\n",
    "def make_ghost_episode():\n",
    "    name, age, sex, pid = make_patient()\n",
    "    spec = random.choice(SPECIALISTS)\n",
    "    drug = random.choice(DRUGS[spec])\n",
    "    proc = random.choice(PROCEDURES[spec])\n",
    "    cost = random.randint(3000, 12000)\n",
    "\n",
    "    prompt = f\"\"\"Patient: {name}, {age}{sex}, ID: {pid}\n",
    "Admitted for: routine checkup\n",
    "Vitals on admission: NOT RECORDED\n",
    "\n",
    "{spec} Report:\n",
    "Procedure performed: {proc}\n",
    "Medication prescribed: {drug}\n",
    "LOS: {random.randint(5,14)} days.\n",
    "Total claim: ${cost:,}\n",
    "\n",
    "Cross-reference check: No nurse notes. No ward entry log. No anesthesia record. Patient signature absent.\n",
    "\n",
    "Analyze for fraud.\"\"\"\n",
    "\n",
    "    return {\"prompt\": prompt, \"ground_truth\": \"ghost_patient\", \"label\": \"REJECTED\"}\n",
    "\n",
    "\n",
    "def make_inflation_episode():\n",
    "    name, age, sex, pid = make_patient()\n",
    "    spec  = random.choice(SPECIALISTS)\n",
    "    diag  = random.choice(DIAGNOSES[spec])\n",
    "    proc  = random.choice(PROCEDURES[spec])\n",
    "    real  = random.randint(1200, 3500)\n",
    "    billed = real * random.randint(4, 9)\n",
    "    qty   = random.randint(8, 25)\n",
    "\n",
    "    prompt = f\"\"\"Patient: {name}, {age}{sex}, ID: {pid}\n",
    "Admitted for: {diag}\n",
    "Vitals on admission: BP {random.randint(110,145)}/{random.randint(70,95)} mmHg, HR {random.randint(62,98)} bpm\n",
    "\n",
    "{spec} Report:\n",
    "Diagnosis: {diag}\n",
    "Procedure: {proc} — billed {qty} units.\n",
    "Standard unit cost: ${real // qty:,} | Claimed unit cost: ${billed // qty:,}\n",
    "LOS: {random.randint(2,5)} days.\n",
    "Total claim: ${billed:,} (market rate for this procedure: ${real:,})\n",
    "\n",
    "Pharmacy audit flag: Drug quantities dispensed do not match prescription records.\n",
    "\n",
    "Analyze for fraud.\"\"\"\n",
    "\n",
    "    return {\"prompt\": prompt, \"ground_truth\": \"claim_inflation\", \"label\": \"REJECTED\"}\n",
    "\n",
    "\n",
    "def make_collusion_episode():\n",
    "    name, age, sex, pid = make_patient()\n",
    "    spec1, spec2 = random.sample(SPECIALISTS, 2)\n",
    "    diag1 = random.choice(DIAGNOSES[spec1])\n",
    "    diag2 = random.choice(DIAGNOSES[spec2])\n",
    "    cost1 = random.randint(3000, 7000)\n",
    "    cost2 = random.randint(3000, 7000)\n",
    "\n",
    "    prompt = f\"\"\"Patient: {name}, {age}{sex}, ID: {pid}\n",
    "Admitted for: {diag1}\n",
    "Vitals on admission: BP {random.randint(110,145)}/{random.randint(70,95)} mmHg, HR {random.randint(62,98)} bpm\n",
    "\n",
    "{spec1} Report:\n",
    "Diagnosis: {diag1}\n",
    "Referred to {spec2} for concurrent management.\n",
    "LOS: {random.randint(3,8)} days. Claim: ${cost1:,}\n",
    "\n",
    "{spec2} Report:\n",
    "Diagnosis: {diag2} (cross-referred by {spec1})\n",
    "All procedures documented as medically necessary.\n",
    "Claim: ${cost2:,}\n",
    "\n",
    "Audit flag: Both consultants share the same billing address. {spec1} referred {random.randint(15,40)} patients to this {spec2} consultant in the last 30 days, all approved without independent review.\n",
    "\n",
    "Analyze for fraud.\"\"\"\n",
    "\n",
    "    return {\"prompt\": prompt, \"ground_truth\": \"collusion\", \"label\": \"REJECTED\"}\n",
    "\n",
    "\n",
    "def build_dataset(n=2000):\n",
    "    counts = {\n",
    "        \"clean\":      int(n * 0.40),\n",
    "        \"ghost\":      int(n * 0.20),\n",
    "        \"inflation\":  int(n * 0.20),\n",
    "        \"collusion\":  int(n * 0.20),\n",
    "    }\n",
    "    rows = []\n",
    "    for _ in range(counts[\"clean\"]):     rows.append(make_clean_episode())\n",
    "    for _ in range(counts[\"ghost\"]):     rows.append(make_ghost_episode())\n",
    "    for _ in range(counts[\"inflation\"]): rows.append(make_inflation_episode())\n",
    "    for _ in range(counts[\"collusion\"]): rows.append(make_collusion_episode())\n",
    "    random.shuffle(rows)\n",
    "    return rows\n",
    "\n",
    "\n",
    "raw_data = build_dataset(2000)\n",
    "\n",
    "# Format as chat turns for GRPO\n",
    "def format_for_grpo(row):\n",
    "    return {\n",
    "        \"prompt\": [\n",
    "            {\"role\": \"system\",  \"content\": SYSTEM_PROMPT},\n",
    "            {\"role\": \"user\",    \"content\": row[\"prompt\"]},\n",
    "        ],\n",
    "        \"ground_truth\": row[\"ground_truth\"],\n",
    "        \"label\":        row[\"label\"],\n",
    "    }\n",
    "\n",
    "formatted = [format_for_grpo(r) for r in raw_data]\n",
    "dataset   = Dataset.from_list(formatted)\n",
    "dataset   = dataset.train_test_split(test_size=0.1, seed=42)\n",
    "\n",
    "print(f\"Train: {len(dataset['train'])} | Eval: {len(dataset['test'])}\")\n",
    "\n",
    "# Label distribution\n",
    "from collections import Counter\n",
    "counts = Counter(r[\"ground_truth\"] for r in raw_data)\n",
    "print(\"Label distribution:\", dict(counts))"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "sec3",
   "metadata": {},
   "source": [
    "## Section 3 — Reward Functions\n",
    "GRPO requires per-sample scalar rewards. No critic network."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "reward_functions",
   "metadata": {},
   "outputs": [],
   "source": [
    "import json\n",
    "import re\n",
    "\n",
    "REQUIRED_KEYS = {\"decision\", \"fraud_flags\", \"reasoning\"}\n",
    "VALID_DECISIONS = {\"APPROVED\", \"REJECTED\"}\n",
    "FRAUD_TYPES = {\"ghost_patient\", \"claim_inflation\", \"collusion\", \"unnecessary_procedure\"}\n",
    "\n",
    "\n",
    "def parse_response(response: str) -> dict | None:\n",
    "    \"\"\"Extract JSON from model response, tolerating markdown code fences.\"\"\"\n",
    "    # Strip markdown fences if present\n",
    "    match = re.search(r\"```(?:json)?\\s*([\\s\\S]*?)```\", response)\n",
    "    if match:\n",
    "        text = match.group(1).strip()\n",
    "    else:\n",
    "        text = response.strip()\n",
    "    try:\n",
    "        return json.loads(text)\n",
    "    except json.JSONDecodeError:\n",
    "        # Try to find a JSON object anywhere in the text\n",
    "        match = re.search(r\"\\{[\\s\\S]*\\}\", text)\n",
    "        if match:\n",
    "            try:\n",
    "                return json.loads(match.group(0))\n",
    "            except json.JSONDecodeError:\n",
    "                return None\n",
    "        return None\n",
    "\n",
    "\n",
    "def format_reward(completions, **kwargs) -> list[float]:\n",
    "    \"\"\"+0.3 if response is valid JSON with all required keys and valid decision value.\"\"\"\n",
    "    rewards = []\n",
    "    for completion in completions:\n",
    "        text = completion[0][\"content\"] if isinstance(completion, list) else completion\n",
    "        parsed = parse_response(text)\n",
    "        if parsed is None:\n",
    "            rewards.append(-0.5)  # Penalty for non-JSON output\n",
    "            continue\n",
    "        if not REQUIRED_KEYS.issubset(parsed.keys()):\n",
    "            rewards.append(-0.2)  # Missing keys\n",
    "            continue\n",
    "        if parsed.get(\"decision\") not in VALID_DECISIONS:\n",
    "            rewards.append(-0.1)  # Invalid decision value\n",
    "            continue\n",
    "        rewards.append(0.3)\n",
    "    return rewards\n",
    "\n",
    "\n",
    "def decision_reward(completions, ground_truth, label, **kwargs) -> list[float]:\n",
    "    \"\"\"\n",
    "    +2.0  correct REJECT on fraud\n",
    "    -3.0  missed fraud (false APPROVED)\n",
    "    +1.0  correct APPROVED on clean\n",
    "    -2.0  false REJECTED on clean\n",
    "    +0.5  correct fraud_type identified in fraud_flags\n",
    "    +0.1  reasoning field has >50 tokens\n",
    "    \"\"\"\n",
    "    rewards = []\n",
    "    for completion, gt, lbl in zip(completions, ground_truth, label):\n",
    "        text   = completion[0][\"content\"] if isinstance(completion, list) else completion\n",
    "        parsed = parse_response(text)\n",
    "        reward = 0.0\n",
    "\n",
    "        if parsed is None:\n",
    "            rewards.append(-1.0)\n",
    "            continue\n",
    "\n",
    "        decision = parsed.get(\"decision\", \"\")\n",
    "        flags    = parsed.get(\"fraud_flags\", [])\n",
    "        reasoning = parsed.get(\"reasoning\", \"\")\n",
    "\n",
    "        is_fraud = (lbl == \"REJECTED\")  # ground truth\n",
    "        predicted_fraud = (decision == \"REJECTED\")\n",
    "\n",
    "        # Core decision reward\n",
    "        if is_fraud and predicted_fraud:\n",
    "            reward += 2.0   # True positive\n",
    "        elif is_fraud and not predicted_fraud:\n",
    "            reward -= 3.0   # False negative — worst outcome\n",
    "        elif not is_fraud and not predicted_fraud:\n",
    "            reward += 1.0   # True negative\n",
    "        else:\n",
    "            reward -= 2.0   # False positive\n",
    "\n",
    "        # Bonus: correct fraud type identification\n",
    "        if is_fraud and isinstance(flags, list):\n",
    "            if gt in flags:\n",
    "                reward += 0.5\n",
    "\n",
    "        # Bonus: substantive reasoning\n",
    "        if isinstance(reasoning, str) and len(reasoning.split()) > 50:\n",
    "            reward += 0.1\n",
    "\n",
    "        rewards.append(reward)\n",
    "    return rewards\n",
    "\n",
    "\n",
    "# Quick sanity check\n",
    "test_good = '[{\"content\": \"{\\\\\"decision\\\\\": \\\\\"REJECTED\\\\\", \\\\\"fraud_flags\\\\\": [\\\\\"ghost_patient\\\\\"], \\\\\"reasoning\\\\\": \\\"' + 'word ' * 55 + '\\\"}\"}]'\n",
    "print(\"Reward functions loaded.\")\n",
    "print(f\"Format reward (valid JSON): {format_reward([[{'content': '{\"decision\": \"REJECTED\", \"fraud_flags\": [\"ghost_patient\"], \"reasoning\": \"test reasoning here with more words to exceed fifty token threshold for bonus reward\"}'}]])}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "sec4",
   "metadata": {},
   "source": [
    "## Section 4 — Load Model + Apply LoRA"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "load_model",
   "metadata": {},
   "outputs": [],
   "source": [
    "from unsloth import FastLanguageModel\n",
    "\n",
    "MAX_SEQ_LENGTH = 2048\n",
    "\n",
    "model, tokenizer = FastLanguageModel.from_pretrained(\n",
    "    model_name      = \"Qwen/Qwen2.5-1.5B-Instruct\",\n",
    "    max_seq_length  = MAX_SEQ_LENGTH,\n",
    "    load_in_4bit    = True,\n",
    "    fast_inference  = False,   # Set True only if using vLLM backend\n",
    ")\n",
    "\n",
    "model = FastLanguageModel.get_peft_model(\n",
    "    model,\n",
    "    r              = 16,\n",
    "    lora_alpha     = 32,\n",
    "    lora_dropout   = 0.05,\n",
    "    target_modules = [\n",
    "        \"q_proj\", \"v_proj\", \"k_proj\", \"o_proj\",\n",
    "        \"gate_proj\", \"up_proj\", \"down_proj\"\n",
    "    ],\n",
    "    bias           = \"none\",\n",
    "    use_gradient_checkpointing = \"unsloth\",\n",
    ")\n",
    "\n",
    "print(model.print_trainable_parameters())"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "sec5",
   "metadata": {},
   "source": [
    "## Section 5 — GRPO Training"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "grpo_train",
   "metadata": {},
   "outputs": [],
   "source": [
    "from trl import GRPOTrainer, GRPOConfig\n",
    "\n",
    "training_args = GRPOConfig(\n",
    "    output_dir                  = \"panacea_oversight_model\",\n",
    "    num_train_epochs            = 3,\n",
    "    per_device_train_batch_size = 2,       # T4 safe with 4-bit + seq 2048\n",
    "    gradient_accumulation_steps = 8,       # effective batch = 16\n",
    "    learning_rate               = 2e-5,\n",
    "    warmup_ratio                = 0.05,\n",
    "    lr_scheduler_type           = \"cosine\",\n",
    "    optim                       = \"adamw_8bit\",\n",
    "    max_grad_norm               = 0.3,\n",
    "    fp16                        = not torch.cuda.is_bf16_supported(),\n",
    "    bf16                        = torch.cuda.is_bf16_supported(),\n",
    "    logging_steps               = 10,\n",
    "    save_strategy               = \"epoch\",\n",
    "    evaluation_strategy         = \"epoch\",\n",
    "    report_to                   = \"none\",\n",
    "    # GRPO-specific\n",
    "    num_generations             = 4,       # completions per prompt for relative scoring\n",
    "    max_new_tokens              = 512,\n",
    "    temperature                 = 0.8,\n",
    "    top_p                       = 0.9,\n",
    "    beta                        = 0.04,    # KL penalty weight (keep low for small models)\n",
    ")\n",
    "\n",
    "trainer = GRPOTrainer(\n",
    "    model          = model,\n",
    "    processing_class = tokenizer,\n",
    "    reward_funcs   = [format_reward, decision_reward],\n",
    "    args           = training_args,\n",
    "    train_dataset  = dataset[\"train\"],\n",
    "    eval_dataset   = dataset[\"test\"],\n",
    ")\n",
    "\n",
    "print(\"Starting GRPO training...\")\n",
    "print(f\"Train samples: {len(dataset['train'])} | Eval samples: {len(dataset['test'])}\")\n",
    "print(f\"Effective batch size: {training_args.per_device_train_batch_size * training_args.gradient_accumulation_steps}\")\n",
    "\n",
    "trainer.train()"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "sec6",
   "metadata": {},
   "source": [
    "## Section 6 — Evaluate on held-out set"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "evaluate",
   "metadata": {},
   "outputs": [],
   "source": [
    "from unsloth import FastLanguageModel as FLM\n",
    "FLM.for_inference(model)  # Enable faster inference mode\n",
    "\n",
    "def run_inference(prompt_messages: list[dict]) -> str:\n",
    "    text = tokenizer.apply_chat_template(\n",
    "        prompt_messages, tokenize=False, add_generation_prompt=True\n",
    "    )\n",
    "    inputs = tokenizer(text, return_tensors=\"pt\").to(model.device)\n",
    "    with torch.no_grad():\n",
    "        output = model.generate(\n",
    "            **inputs,\n",
    "            max_new_tokens = 512,\n",
    "            temperature    = 0.1,   # Low temp for eval\n",
    "            top_p          = 0.9,\n",
    "            do_sample      = True,\n",
    "            pad_token_id   = tokenizer.eos_token_id,\n",
    "        )\n",
    "    new_tokens = output[0][inputs[\"input_ids\"].shape[1]:]\n",
    "    return tokenizer.decode(new_tokens, skip_special_tokens=True)\n",
    "\n",
    "\n",
    "# Evaluate 50 samples from test set\n",
    "eval_samples = dataset[\"test\"].select(range(min(50, len(dataset[\"test\"]))))\n",
    "\n",
    "results = {\"tp\": 0, \"tn\": 0, \"fp\": 0, \"fn\": 0, \"parse_errors\": 0}\n",
    "\n",
    "for sample in eval_samples:\n",
    "    response = run_inference(sample[\"prompt\"])\n",
    "    parsed   = parse_response(response)\n",
    "\n",
    "    if parsed is None:\n",
    "        results[\"parse_errors\"] += 1\n",
    "        continue\n",
    "\n",
    "    predicted = parsed.get(\"decision\", \"\")\n",
    "    actual    = sample[\"label\"]\n",
    "\n",
    "    if actual == \"REJECTED\" and predicted == \"REJECTED\": results[\"tp\"] += 1\n",
    "    elif actual == \"APPROVED\" and predicted == \"APPROVED\": results[\"tn\"] += 1\n",
    "    elif actual == \"APPROVED\" and predicted == \"REJECTED\": results[\"fp\"] += 1\n",
    "    elif actual == \"REJECTED\" and predicted == \"APPROVED\": results[\"fn\"] += 1\n",
    "\n",
    "total = sum(results.values())\n",
    "correct = results[\"tp\"] + results[\"tn\"]\n",
    "precision = results[\"tp\"] / max(results[\"tp\"] + results[\"fp\"], 1)\n",
    "recall    = results[\"tp\"] / max(results[\"tp\"] + results[\"fn\"], 1)\n",
    "f1        = 2 * precision * recall / max(precision + recall, 1e-9)\n",
    "\n",
    "print(f\"\\n{'='*40}\")\n",
    "print(f\"Eval Results (n={total})\")\n",
    "print(f\"{'='*40}\")\n",
    "print(f\"Accuracy:  {correct/total*100:.1f}%\")\n",
    "print(f\"Precision: {precision*100:.1f}%\")\n",
    "print(f\"Recall:    {recall*100:.1f}%\")\n",
    "print(f\"F1 Score:  {f1*100:.1f}%\")\n",
    "print(f\"False Negatives (missed fraud): {results['fn']}  ← must be low\")\n",
    "print(f\"Parse errors: {results['parse_errors']}\")\n",
    "print(f\"{'='*40}\")"
   ]
  },
