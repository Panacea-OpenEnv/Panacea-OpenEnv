   "source": [
    "## Section 8 — Serve via FastAPI + ngrok\n",
    "Exposes a live `/generate` endpoint for the hackathon demo.  \n",
    "Judges can hit `POST https://<ngrok-url>/generate` with `{\"prompt\": \"...\"}` and get back fraud analysis."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "install_serve",
   "metadata": {},
   "outputs": [],
   "source": [
    "%%capture\n",
    "!pip install fastapi uvicorn pyngrok nest-asyncio"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "ngrok_token",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Get a free ngrok token at https://dashboard.ngrok.com/signup\n",
    "NGROK_AUTH_TOKEN = \"\"  # <-- paste your token here\n",
    "\n",
    "if not NGROK_AUTH_TOKEN:\n",
    "    print(\"WARNING: No ngrok token set. The server will start but won't be publicly accessible.\")\n",
    "    print(\"Get a free token at https://dashboard.ngrok.com/signup\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "serve",
   "metadata": {},
   "outputs": [],
   "source": [
    "import nest_asyncio\n",
    "import uvicorn\n",
    "import threading\n",
    "from fastapi import FastAPI, HTTPException\n",
    "from pydantic import BaseModel\n",
    "from pyngrok import ngrok, conf\n",
    "\n",
    "nest_asyncio.apply()\n",
    "\n",
    "# Make sure model is in inference mode\n",
    "FLM.for_inference(model)\n",
    "\n",
    "app = FastAPI(title=\"Panacea Oversight Agent\", version=\"1.0\")\n",
    "\n",
    "\n",
    "class GenerateRequest(BaseModel):\n",
    "    prompt: str\n",
    "    temperature: float = 0.1\n",
    "    max_new_tokens: int = 512\n",
    "\n",
    "\n",
    "class GenerateResponse(BaseModel):\n",
    "    decision: str\n",
    "    fraud_flags: list\n",
    "    reasoning: str\n",
    "    raw_output: str\n",
    "\n",
    "\n",
    "@app.get(\"/health\")\n",
    "def health():\n",
    "    return {\"status\": \"ok\", \"model\": \"panacea-oversight-v1\"}\n",
    "\n",
    "\n",
    "@app.post(\"/generate\", response_model=GenerateResponse)\n",
    "def generate(req: GenerateRequest):\n",
    "    messages = [\n",
    "        {\"role\": \"system\", \"content\": SYSTEM_PROMPT},\n",
    "        {\"role\": \"user\",   \"content\": req.prompt},\n",
    "    ]\n",
    "    raw = run_inference(messages)\n",
    "    parsed = parse_response(raw)\n",
    "\n",
    "    if parsed is None:\n",
    "        raise HTTPException(status_code=422, detail=f\"Model returned non-JSON output: {raw[:200]}\")\n",
    "\n",
    "    return GenerateResponse(\n",
    "        decision    = parsed.get(\"decision\", \"UNKNOWN\"),\n",
    "        fraud_flags = parsed.get(\"fraud_flags\", []),\n",
    "        reasoning   = parsed.get(\"reasoning\", \"\"),\n",
    "        raw_output  = raw,\n",
    "    )\n",
    "\n",
    "\n",
    "@app.post(\"/analyze\")\n",
    "def analyze_claim(req: GenerateRequest):\n",
    "    \"\"\"Alias for /generate with additional metadata.\"\"\"\n",
    "    result = generate(req)\n",
    "    return {\n",
    "        **result.dict(),\n",
    "        \"model\": \"panacea-oversight-v1\",\n",
    "        \"fraud_detected\": result.decision == \"REJECTED\",\n",
    "    }\n",
    "\n",
    "\n",
    "# Start ngrok tunnel\n",
    "public_url = None\n",
    "if NGROK_AUTH_TOKEN:\n",
    "    conf.get_default().auth_token = NGROK_AUTH_TOKEN\n",
    "    public_url = ngrok.connect(8000).public_url\n",
    "    print(f\"\\n{'='*50}\")\n",
    "    print(f\"PUBLIC URL: {public_url}\")\n",
    "    print(f\"Swagger UI: {public_url}/docs\")\n",
    "    print(f\"Health:     {public_url}/health\")\n",
    "    print(f\"Generate:   POST {public_url}/generate\")\n",
    "    print(f\"{'='*50}\\n\")\n",
    "else:\n",
    "    print(\"Server running locally at http://localhost:8000\")\n",
    "    print(\"Swagger UI: http://localhost:8000/docs\")\n",
    "\n",
    "# Run in background thread so Colab cell doesn't block\n",
    "def run_server():\n",
    "    uvicorn.run(app, host=\"0.0.0.0\", port=8000, log_level=\"warning\")\n",
    "\n",
    "thread = threading.Thread(target=run_server, daemon=True)\n",
    "thread.start()\n",
    "print(\"Server started.\")"
   ]
  },
